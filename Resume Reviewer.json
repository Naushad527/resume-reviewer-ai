        "text": "={{ $node[\"Extract from File\"].json.text }}",
        "options": {
          "systemMessage": "You are a strict resume parsing engine. Extract ONLY information explicitly present in the text. Never invent, infer, or guess values. Output ONLY valid JSON, no markdown fences, no commentary.\n\nSchema:\n{\n  \"name\": string, \"email\": string, \"phone\": string,\n  \"linkedin\": string|null, \"github\": string|null, \"portfolio\": string|null,\n  \"location\": string, \"summary\": string|null,\n  \"education\": [{\"institution\",\"degree\",\"field\",\"cgpa_or_percent\",\"start_date\",\"end_date\"}],\n  \"experience\": [{\"company\",\"role\",\"start_date\",\"end_date\",\"bullets\":[string]}],\n  \"projects\": [{\"name\",\"tech_stack\":[string],\"bullets\":[string],\"link\"}],\n  \"skills\": {\"technical\":[string],\"tools\":[string],\"soft\":[string]},\n  \"certifications\": [string], \"achievements\": [string]\n}\nUse null or [] for missing sections. Preserve bullet wording as-is. Normalize dates to \"MMM YYYY\"."
        }
      },
