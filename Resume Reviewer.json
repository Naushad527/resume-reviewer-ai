    {
      "parameters": {
        "promptType": "define",
        "text": "=Resume Details:\n{{ $node[\"Resume Parser\"].json.output }}\n\nATS Analysis:\n{{ $node[\"ATS Scorer\"].json.output }}",
        "options": {
          "systemMessage": "Based on the Resume Details and ATS Analysis below, generate a final hiring-manager-style review. Be specific — reference actual project/skill names from the resume, not generic statements.\n\nIMPORTANT: Keep every bullet point under 12 words. Be concise — this will be sent as a WhatsApp message with a strict length limit.\n\nResume Details:\n{{ $node[\"Resume Parser\"].json.output }}\n\nATS Analysis:\n{{ $node[\"ATS Scorer\"].json.output }}\n\nOutput ONLY JSON:\n{\n  \"ats_score\": number out of 100 (weighted average ×10: ats 30%, skills 20%, projects 20%, experience 15%, format 10%, education 5%),\n  \"verdict\": \"Excellent\" (85-100) | \"Good\" (70-84) | \"Average\" (50-69) | \"Below Average\" (30-49) | \"Poor\" (0-29),\n  \"strengths\": [2-3 short specific points, max 12 words each],\n  \"weaknesses\": [2-3 short specific points, max 12 words each],\n  \"missing_skills\": [3-4 short skill names only, no explanations],\n  \"suggested_improvements\": [2-3 short specific points, max 12 words each],\n  \"one_line_summary\": string, max 20 words\n}"
        }
      },
      "type": "@n8n/n8n-nodes-langchain.agent",
      "typeVersion": 3.1,
