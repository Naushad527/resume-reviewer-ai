    {
      "parameters": {
        "jsCode": "let raw = $input.first().json.output;\n\nraw = raw.replace(/```json|```/g, '').trim();\n\nlet data;\ntry {\n  data = JSON.parse(raw);\n} catch (e) {\n  return [{ json: { message: \"Sorry, something went wrong while generating your review. Please try again.\" } }];\n}\n\nconst limit = (arr, n) => (arr || []).slice(0, n);\n\nconst message = `📋 *Resume ATS Review*\n\n⭐ *ATS Score:* ${data.ats_score}/100\n🎯 *Verdict:* ${data.verdict}\n\n✅ *Strengths:*\n${limit(data.strengths, 3).map(s => `• ${s}`).join('\\n')}\n\n⚠️ *Weaknesses:*\n${limit(data.weaknesses, 3).map(w => `• ${w}`).join('\\n')}\n\n🧩 *Missing Skills:*\n${limit(data.missing_skills, 4).map(s => `• ${s}`).join('\\n')}\n\n💡 *Suggested Improvements:*\n${limit(data.suggested_improvements, 3).map(i => `• ${i}`).join('\\n')}\n\n📝 *Summary:* ${data.one_line_summary}\n\n_(AI-estimated score based on resume content)_`;\n\nreturn [{ json: { message } }];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
